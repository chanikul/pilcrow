---
/**
 * Pilcrow Playground — Settings panel.
 *
 * Surfaces five typographic controls to the playground user:
 *   1. Font (Level 2: searchable Google Fonts combobox via FontPicker.astro)
 *   2. Drop cap (toggle, font-aware)
 *   3. Hyphenation (toggle, default ON)
 *   4. Measure (50/60/65/70/75 ch stepper)
 *   5. Line height (1.4/1.5/1.55/1.6/1.7 stepper)
 *
 * Level 2 changes (Spec 01):
 *   - Row 1 (font) is now <FontPicker /> — a D1 combobox backed by
 *     `src/lib/playground/google-fonts-manifest.json`.
 *   - `readSettings()` reads the font from `[data-font-picker]`'s
 *     `data-current-font` attribute (set by FontPicker.astro's hydration).
 *   - `updateDropCapAvailability()` now accepts a `number | null` weight
 *     directly (FontPicker derives this from the manifest / runtime detection).
 *   - A `pilcrow:font-picker-changed` listener drives font-aware controls
 *     (drop-cap toggle) and triggers a `pilcrow:settings-changed` dispatch
 *     whenever the user picks a new family.
 *
 * Event contract — FROZEN (Level 1; Level 2 must not break it):
 *
 *   type: 'pilcrow:settings-changed'
 *   detail: {
 *     settings: {
 *       font: string;          // full family name
 *       dropCap: boolean;
 *       hyphenation: boolean;
 *       measure: number;       // 50 | 60 | 65 | 70 | 75 (ch)
 *       lineHeight: number;    // 1.4 | 1.5 | 1.55 | 1.6 | 1.7
 *     };
 *     changed: 'font' | 'dropCap' | 'hyphenation' | 'measure' |
 *              'lineHeight' | null;
 *     source: 'user' | 'init' | 'restore';
 *   }
 *   dispatched on: document, bubbles: true
 */

import FontPicker from './FontPicker.astro';

const MEASURES = [50, 60, 65, 70, 75] as const;
const LINE_HEIGHTS = [1.4, 1.5, 1.55, 1.6, 1.7] as const;

const DEFAULT_DROP_CAP = true;
const DEFAULT_HYPHENATION = true;
const DEFAULT_MEASURE = 65;
const DEFAULT_LINE_HEIGHT = 1.55;
---

<h2 id="playground-settings-label" class="settings-label">Settings</h2>

<form class="settings-form" aria-labelledby="playground-settings-label" data-settings-form>
  {/* ─── Row 1: font picker (Level 2 — searchable combobox) ───────── */}
  <fieldset class="settings-row settings-row-fonts">
    <legend class="settings-legend">Font</legend>
    <FontPicker />
  </fieldset>

  {/* ─── Row 2: other controls (toggles + steppers) ───────────────── */}
  <div class="settings-row settings-row-controls">
    {/* Drop-cap toggle — checkbox style, font-aware (Q C). */}
    <fieldset class="settings-control settings-control-toggle">
      <legend class="settings-legend">Drop cap</legend>
      <label class="toggle-label">
        <input
          type="checkbox"
          name="drop-cap"
          data-drop-cap
          checked={DEFAULT_DROP_CAP}
        />
        <span class="toggle-text">On</span>
      </label>
    </fieldset>

    {/* Hyphenation toggle — independent of font, default ON. */}
    <fieldset class="settings-control settings-control-toggle">
      <legend class="settings-legend">Hyphenation</legend>
      <label class="toggle-label">
        <input
          type="checkbox"
          name="hyphenation"
          data-hyphenation
          checked={DEFAULT_HYPHENATION}
        />
        <span class="toggle-text">On</span>
      </label>
    </fieldset>

    {/* Measure stepper — discrete radio buttons. */}
    <fieldset class="settings-control settings-control-stepper">
      <legend class="settings-legend">Measure</legend>
      <div class="stepper" role="radiogroup" aria-label="Measure (column width in characters)">
        {MEASURES.map((m) => (
          <label class="stepper-option">
            <input
              type="radio"
              name="measure"
              value={m}
              data-measure
              checked={m === DEFAULT_MEASURE}
            />
            <span class="stepper-text">{m}</span>
          </label>
        ))}
      </div>
    </fieldset>

    {/* Line-height stepper — discrete radio buttons. */}
    <fieldset class="settings-control settings-control-stepper">
      <legend class="settings-legend">Line height</legend>
      <div class="stepper" role="radiogroup" aria-label="Line height">
        {LINE_HEIGHTS.map((lh) => (
          <label class="stepper-option">
            <input
              type="radio"
              name="line-height"
              value={lh}
              data-line-height
              checked={lh === DEFAULT_LINE_HEIGHT}
            />
            <span class="stepper-text">{lh}</span>
          </label>
        ))}
      </div>
    </fieldset>

    {/* ─── Copy-HTML + Share actions (sub-tasks 8 + 9) ────────────────────
        Two tool affordances in the same cell. Inter chrome register;
        subdued border like the stepper / swatch surfaces. Both buttons
        are JS-disabled no-ops (layout stable). Share encodes settings +
        markdown into a URL hash via lz-string (sub-task 9). */}
    <div class="settings-control settings-control-action">
      <span class="settings-legend" id="copy-html-legend">Output</span>
      <div class="action-buttons">
        <button
          type="button"
          class="copy-html-button"
          data-copy-html
          aria-labelledby="copy-html-legend"
          aria-live="polite"
        >
          <span data-copy-html-label>Copy HTML</span>
        </button>
        <button
          type="button"
          class="copy-html-button share-button"
          data-share-url
          aria-live="polite"
          aria-label="Share playground state as URL"
        >
          <span data-share-url-label>Share</span>
        </button>
      </div>
    </div>
  </div>
</form>

<script>
  /**
   * Settings hydration — Level 2 update (Spec 01).
   *
   * The swatch-based font picker from Level 1 has been replaced by
   * FontPicker.astro (a D1 combobox). Settings.astro now:
   *   - Reads the current font from `[data-font-picker]`'s `data-current-font`
   *     attribute (managed by FontPicker.astro's hydration script).
   *   - Listens for `pilcrow:font-picker-changed` events dispatched by
   *     FontPicker.astro, then updates drop-cap availability and fires
   *     `pilcrow:settings-changed` with the full settings payload.
   *   - Everything else (drop-cap toggle, hyphenation, measure, line-height,
   *     copy-HTML, share-URL) is unchanged from Level 1.
   *
   * The `pilcrow:settings-changed` contract is frozen and must not change.
   */

  interface PlaygroundSettings {
    font: string;
    dropCap: boolean;
    hyphenation: boolean;
    measure: number;
    lineHeight: number;
  }
  type SettingsKey = keyof PlaygroundSettings;
  type DispatchSource = 'user' | 'init' | 'restore';

  interface SettingsChangedDetail {
    settings: PlaygroundSettings;
    changed: SettingsKey | null;
    source: DispatchSource;
  }

  interface FontPickerChangedDetail {
    family: string;
    dropCapWeight: number | null;
    isCustom: boolean;
  }

  interface PlaygroundWindow extends Window {
    __pilcrowSettings?: PlaygroundSettings;
  }

  const form = document.querySelector<HTMLFormElement>('[data-settings-form]');
  if (form) {
    const fontPickerEl = form.querySelector<HTMLDivElement>('[data-font-picker]');
    const dropCapInput = form.querySelector<HTMLInputElement>('[data-drop-cap]');
    const hyphenationInput = form.querySelector<HTMLInputElement>('[data-hyphenation]');
    const measureInputs = Array.from(
      form.querySelectorAll<HTMLInputElement>('[data-measure]'),
    );
    const lineHeightInputs = Array.from(
      form.querySelectorAll<HTMLInputElement>('[data-line-height]'),
    );
    const dropCapToggleLabel =
      dropCapInput?.closest<HTMLLabelElement>('.toggle-label') ?? null;

    // Track the active drop-cap weight for the current font. Updated on
    // `pilcrow:font-picker-changed` events. Used by buildInlinedCSS so
    // the copy-HTML output carries the correct drop-cap weight.
    let activeDropCapWeight: number | null = 600; // Fraunces default

    // ─── Read current state from DOM (post-default rendering) ───────────
    // Level 2: font is read from the FontPicker host's `data-current-font`
    // attribute, not from swatch aria-checked states (swatches are gone).
    const readSettings = (): PlaygroundSettings => {
      const font = fontPickerEl?.dataset.currentFont ?? 'Fraunces';
      const dropCap = dropCapInput?.checked ?? true;
      const hyphenation = hyphenationInput?.checked ?? true;
      const measureRadio = measureInputs.find((i) => i.checked) ?? measureInputs[0];
      const measure = measureRadio ? Number(measureRadio.value) : 65;
      const lineHeightRadio = lineHeightInputs.find((i) => i.checked) ?? lineHeightInputs[0];
      const lineHeight = lineHeightRadio ? Number(lineHeightRadio.value) : 1.55;
      return { font, dropCap, hyphenation, measure, lineHeight };
    };

    // ─── Drop-cap-by-font enforcement ─────────────────────────────────────
    // Level 2: `updateDropCapAvailability` now accepts a `number | null`
    // weight directly from the FontPicker event detail (manifest-derived or
    // runtime-detected), instead of looking up a swatch's data attribute.
    // The disable-with-tooltip logic is unchanged from Level 1.
    const updateDropCapAvailability = (dropCapWeight: number | null): void => {
      if (!dropCapInput || !dropCapToggleLabel) return;
      const hasWeight = dropCapWeight !== null;
      if (hasWeight) {
        dropCapInput.disabled = false;
        dropCapToggleLabel.removeAttribute('title');
        dropCapToggleLabel.classList.remove('toggle-label-disabled');
      } else {
        dropCapInput.disabled = true;
        dropCapInput.checked = false; // silently OFF
        dropCapToggleLabel.title =
          'Drop cap requires a 500–600 weight; this font ships only 400/700.';
        dropCapToggleLabel.classList.add('toggle-label-disabled');
      }
    };

    // ─── Event dispatch ──────────────────────────────────────────────────
    const dispatch = (changed: SettingsKey | null, source: DispatchSource): void => {
      const settings = readSettings();
      (window as PlaygroundWindow).__pilcrowSettings = settings;
      const event = new CustomEvent<SettingsChangedDetail>(
        'pilcrow:settings-changed',
        { detail: { settings, changed, source }, bubbles: true },
      );
      document.dispatchEvent(event);
    };

    // ─── Listen for FontPicker font changes ──────────────────────────────
    // FontPicker.astro dispatches `pilcrow:font-picker-changed` after each
    // successful font load. We update drop-cap availability and fire the
    // full settings-changed event with `changed: 'font'`.
    document.addEventListener('pilcrow:font-picker-changed', (ev) => {
      const detail = (ev as CustomEvent<FontPickerChangedDetail>).detail;
      if (!detail) return;
      activeDropCapWeight = detail.dropCapWeight;
      updateDropCapAvailability(detail.dropCapWeight);
      dispatch('font', 'user');
    });

    // ─── Wire drop-cap / hyphenation ─────────────────────────────────────
    if (dropCapInput) {
      dropCapInput.addEventListener('change', () => dispatch('dropCap', 'user'));
    }
    if (hyphenationInput) {
      hyphenationInput.addEventListener('change', () => dispatch('hyphenation', 'user'));
    }

    // ─── Wire measure / line-height steppers ─────────────────────────────
    for (const input of measureInputs) {
      input.addEventListener('change', () => {
        if (input.checked) dispatch('measure', 'user');
      });
    }
    for (const input of lineHeightInputs) {
      input.addEventListener('change', () => {
        if (input.checked) dispatch('lineHeight', 'user');
      });
    }

    // ─── Initial dispatch (THE init contract) ────────────────────────────
    // Unchanged from Level 1: yield via setTimeout(0) so Preview.astro's
    // listener (attached one microtask after Settings.astro's synchronous
    // body) has time to register (learnings 2026-05-07).
    // Initial drop-cap weight: Fraunces = 600 (manifest dropCapWeightOverride).
    setTimeout(() => {
      updateDropCapAvailability(activeDropCapWeight);
      dispatch(null, 'init');
    }, 0);

    // ─── Copy-HTML action ────────────────────────────────────────────────
    // Level 2 update: buildGoogleFontsURL now uses `buildCopyHTMLFontsURL`
    // from `google-fonts.ts` for non-manifest and custom families. For the
    // copy-HTML drop-cap weight, use `activeDropCapWeight` (set by the
    // `pilcrow:font-picker-changed` listener) rather than a swatch lookup.
    const copyButton = document.querySelector<HTMLButtonElement>('[data-copy-html]');
    const copyLabel = document.querySelector<HTMLSpanElement>('[data-copy-html-label]');

    const buildInlinedCSS = (settings: PlaygroundSettings): string => {
      const familyToken = `"${settings.font}"`;
      const fontStack = `${familyToken}, ui-serif, Georgia, "Times New Roman", serif`;
      // Use activeDropCapWeight (updated on every font-picker-changed event).
      // Fall back to 600 (a safe editorial default) for families where the
      // picker hasn't fired yet (e.g. on the initial Fraunces render).
      const dropCapWeight = activeDropCapWeight ?? 600;
      return [
        `html { font-size: 19px; }`,
        `body {`,
        `  font-family: ${fontStack};`,
        `  line-height: ${settings.lineHeight};`,
        `  color: #1a1a1a;`,
        `  background: #fafaf7;`,
        `  margin: 0;`,
        `  padding: 4rem 1rem 2rem;`,
        `}`,
        `.post-body {`,
        `  max-width: ${settings.measure}ch;`,
        `  margin: 0 auto;`,
        `}`,
        `.post-body p { margin: 0 0 1.8rem; }`,
        `.post-body p:empty { margin: 0; }`,
        `.pt-line { display: block; white-space: nowrap; overflow-wrap: anywhere; }`,
        `.lede .drop-cap {`,
        `  float: left;`,
        `  font-size: 4.6em;`,
        `  line-height: 0.85;`,
        `  font-weight: ${dropCapWeight};`,
        `  padding: 0.05em 0.08em 0 0;`,
        `  margin-top: 0.05em;`,
        `}`,
        `.lede + p { clear: left; }`,
        `.visually-hidden {`,
        `  position: absolute;`,
        `  width: 1px;`,
        `  height: 1px;`,
        `  overflow: hidden;`,
        `  clip: rect(0, 0, 0, 0);`,
        `  white-space: nowrap;`,
        `}`,
      ].join('\n');
    };

    // Build a Google Fonts CSS2 URL for the given family for use in the
    // exported copy-HTML document. Uses explicit weight list derived from
    // the active drop-cap weight to keep the export minimal.
    const buildCopyFontsURL = (settings: PlaygroundSettings): string => {
      const family = settings.font;
      const encodedFamily = family.replace(/ /g, '+');
      const base = 'https://fonts.googleapis.com/css2';
      // Body-relevant weight list: 400 + dropCapWeight (if set) + 700.
      const weightNums = Array.from(
        new Set([400, ...(activeDropCapWeight !== null ? [activeDropCapWeight] : []), 700]),
      ).sort((a, b) => a - b);
      const uprightTuples = weightNums.map((w) => `0,${w}`).join(';');
      // Request italic 400 (omit if the family has no italic — API is
      // permissive and simply returns what exists).
      return `${base}?family=${encodedFamily}:ital,wght@${uprightTuples};1,400&display=swap`;
    };

    const buildCopyableHTML = (): string | null => {
      const host = document.getElementById('playground-preview-host');
      if (!host) return null;
      const settings: PlaygroundSettings =
        (window as PlaygroundWindow).__pilcrowSettings ?? readSettings();
      const css = buildInlinedCSS(settings);
      const fontsURL = buildCopyFontsURL(settings);
      const innerHTML = host.innerHTML;
      return [
        `<!DOCTYPE html>`,
        `<!-- Typeset by Pilcrow (https://pilcrow.page/playground).`,
        `     Fonts served by Google Fonts (https://fonts.google.com).`,
        `     For a self-hosted version, download the woff2 files via`,
        `     google-webfonts-helper or fontsource.org and swap the <link>`,
        `     below for inlined @font-face declarations. -->`,
        `<html lang="en">`,
        `<head>`,
        `<meta charset="utf-8">`,
        `<title>Pilcrow typeset</title>`,
        `<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>`,
        `<link rel="stylesheet" href="${fontsURL}">`,
        `<style>`,
        css,
        `</style>`,
        `</head>`,
        `<body>`,
        `<div class="post-body">`,
        innerHTML,
        `</div>`,
        `</body>`,
        `</html>`,
      ].join('\n');
    };

    if (copyButton && copyLabel) {
      const REVERT_MS = 1500;
      let revertTimer: number | null = null;
      const setLabel = (text: string): void => { copyLabel.textContent = text; };
      const scheduleRevert = (): void => {
        if (revertTimer !== null) window.clearTimeout(revertTimer);
        revertTimer = window.setTimeout(() => {
          setLabel('Copy HTML');
          copyButton.removeAttribute('data-state');
          revertTimer = null;
        }, REVERT_MS);
      };

      copyButton.addEventListener('click', async () => {
        const html = buildCopyableHTML();
        if (html === null) {
          setLabel('Nothing to copy');
          copyButton.setAttribute('data-state', 'error');
          scheduleRevert();
          return;
        }
        try {
          await navigator.clipboard.writeText(html);
          setLabel('Copied!');
          copyButton.setAttribute('data-state', 'success');
          scheduleRevert();
        } catch (err) {
          // eslint-disable-next-line no-console
          console.warn('[pilcrow:copy-html] clipboard write failed:', err);
          // eslint-disable-next-line no-console
          console.log('[pilcrow:copy-html] payload (manual grab):\n' + html);
          setLabel('Copy failed — see console');
          copyButton.setAttribute('data-state', 'error');
          scheduleRevert();
        }
      });
    }

    // ─── Share-URL action (unchanged from Level 1) ────────────────────────
    const shareButton = document.querySelector<HTMLButtonElement>('[data-share-url]');
    const shareLabel = document.querySelector<HTMLSpanElement>('[data-share-url-label]');

    if (shareButton && shareLabel) {
      const SHARE_REVERT_MS = 1500;
      let shareRevertTimer: number | null = null;
      const setShareLabel = (text: string): void => { shareLabel.textContent = text; };
      const scheduleShareRevert = (): void => {
        if (shareRevertTimer !== null) window.clearTimeout(shareRevertTimer);
        shareRevertTimer = window.setTimeout(() => {
          setShareLabel('Share');
          shareButton.removeAttribute('data-state');
          shareRevertTimer = null;
        }, SHARE_REVERT_MS);
      };

      shareButton.addEventListener('click', async () => {
        const textarea = document.getElementById(
          'playground-editor-textarea',
        ) as HTMLTextAreaElement | null;
        const markdown = textarea?.value ?? '';
        const settings: PlaygroundSettings =
          (window as PlaygroundWindow).__pilcrowSettings ?? readSettings();

        const { encodeShareURL, SHARE_URL_LONG_THRESHOLD } = await import(
          '../../lib/playground/share-url.ts'
        );
        const hash = encodeShareURL({ settings, markdown });
        window.location.hash = hash.slice(1);
        const shareURL = window.location.href;
        const isLong = hash.length > SHARE_URL_LONG_THRESHOLD;

        try {
          await navigator.clipboard.writeText(shareURL);
          setShareLabel(isLong ? 'Copied — long URL' : 'Copied!');
          shareButton.setAttribute('data-state', isLong ? 'warn' : 'success');
          scheduleShareRevert();
        } catch (err) {
          // eslint-disable-next-line no-console
          console.warn('[pilcrow:share-url] clipboard write failed:', err);
          setShareLabel('URL updated');
          shareButton.setAttribute('data-state', 'success');
          scheduleShareRevert();
        }
      });
    }
  }
</script>

<style>
  /* Top-level settings label — same Inter small-caps recipe used in
     Editor.astro and Preview.astro for tool-register chrome. */
  .settings-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .settings-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Fieldsets unstyled — let the children own visual rhythm. */
  .settings-form fieldset {
    border: 0;
    margin: 0;
    padding: 0;
    min-width: 0;
  }

  .settings-legend {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.5rem;
    padding: 0;
  }

  /* ─── Row 1 — font picker (Level 2: FontPicker.astro) ──────────────────
     The swatch grid from Level 1 is gone. FontPicker.astro owns all
     font-row layout and style. Settings.astro just gives it the fieldset
     shell (settings-row-fonts) and the legend. */

  /* ─── Row 2 — controls ───────────────────────────────────────────────── */
  /* Five cells: drop-cap, hyphenation, measure stepper, line-height stepper,
     copy-HTML action. The action sits at the right edge so it reads as a
     terminal control — the user has configured the typeset; the button is
     the way out. */
  .settings-row-controls {
    display: grid;
    grid-template-columns:
      auto auto auto auto 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  /* The action cell pushes its button flush to the right edge so the chrome
     ends with a clean trailing affordance rather than a left-aligned button
     floating next to the line-height stepper. */
  .settings-control-action {
    justify-self: end;
    text-align: right;
  }

  .settings-control {
    /* Each control has its own legend via fieldset; the row's grid handles
       horizontal placement. */
  }

  /* ─── Toggle (drop cap, hyphenation) ─────────────────────────────────── */
  .toggle-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    color: var(--ink);
    cursor: pointer;
    user-select: none;
  }

  .toggle-label input[type='checkbox'] {
    /* Real checkbox, slightly larger to match the editorial register's
       restraint. Native rendering — keeps a11y free. */
    width: 1rem;
    height: 1rem;
    margin: 0;
    accent-color: var(--accent);
    cursor: pointer;
  }

  .toggle-label-disabled {
    color: var(--muted);
    cursor: not-allowed;
  }

  .toggle-label-disabled input[type='checkbox'] {
    cursor: not-allowed;
  }

  .toggle-label:focus-within {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  /* ─── Stepper (measure, line-height) ─────────────────────────────────── */
  .stepper {
    display: flex;
    gap: 0;
    border: 1px solid var(--rule);
    background: var(--paper);
    /* Avoid double border on internal cells via collapsing. */
    width: max-content;
  }

  .stepper-option {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.7rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8rem;
    color: var(--muted);
    cursor: pointer;
    border-right: 1px solid var(--rule);
    user-select: none;
    min-width: 2.5rem;
    text-align: center;
  }

  .stepper-option:last-child {
    border-right: 0;
  }

  /* Hide the actual radio inputs — the labels become the UI. */
  .stepper-option input[type='radio'] {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  /* Selected stepper option — ink text on accent underline. */
  .stepper-option:has(input[type='radio']:checked) {
    color: var(--ink);
    box-shadow: inset 0 -2px 0 0 var(--accent);
  }

  /* Focus state — accent outline on the label when its input has focus. */
  .stepper-option:has(input[type='radio']:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ─── Action button group (copy-HTML + share) ────────────────────────
     Two buttons side-by-side in the action cell. No gap between them —
     they read as a single compound control, each with a 1px border. */
  .action-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* ─── Copy-HTML / Share action ───────────────────────────────────────
     Tool affordance, NOT a CTA. Inter chrome register, ruled border like
     the stepper / swatch surfaces, accent on hover. The label swap to
     "Copied!" / "Copied — long URL" is the entire success feedback — no
     toast, no modal. */
  .copy-html-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    user-select: none;
    /* Reset button defaults that drift visual register otherwise. */
    line-height: 1.2;
    transition: border-color 120ms ease, color 120ms ease;
