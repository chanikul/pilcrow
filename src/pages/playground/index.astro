---
/**
 * Pilcrow Playground — page shell (sub-task 4 of PILCROW_PLAYGROUND_PLAN.md).
 *
 * This is intentionally a SHELL: route, layout chrome, and three labelled
 * placeholder regions for the editor pane (sub-task 5), the settings panel
 * (sub-task 6), and the preview pane (sub-task 7). No BrowserRenderer
 * dependency is wired here; the page must render with JavaScript disabled.
 *
 * Layout topology (Question B default — two-column with top settings bar):
 *   Desktop (≥768px):
 *     ┌──────────────────────────────────────────────────┐
 *     │ Settings bar (top, full-width)                   │
 *     ├──────────────────────────┬───────────────────────┤
 *     │ Editor pane (left)       │ Preview pane (right)  │
 *     └──────────────────────────┴───────────────────────┘
 *   Mobile (<768px): editor / preview on a CSS-driven radio-tab toggle;
 *   settings collapse into a drawer-like region above. Pure CSS — no JS.
 *
 * Visual register (Question E default — contrast):
 *   - Chrome (settings labels, buttons, placeholder labels): Inter — tool register.
 *   - Preview pane: Fraunces — editorial register (the product the user is here to see).
 *
 * Empty-state strategy (Question D default applied):
 *   The editor placeholder pre-loads a generic ~80-word stand-in paragraph.
 *   The intended invitation prose (drop-cap + hyphenation + footnote demo) is
 *   a FOLLOW-UP editorial-writer task before ship. This stand-in is a marker,
 *   not the final copy.
 */

import Base from '../../layouts/Base.astro';
import Editor from '../../components/playground/Editor.astro';
import Preview from '../../components/playground/Preview.astro';
import Settings from '../../components/playground/Settings.astro';

/**
 * Sub-task 9 — share-URL state restoration.
 *
 * The page-load restoration script (in the <script> block below) runs as
 * an Astro deferred ES module, which means it executes in document order
 * after DOMContentLoaded — BEFORE Settings.astro's hydration script fires
 * its setTimeout(0) init dispatch. This ordering is critical:
 *
 *   1. This script: parse hash → mutate form DOM → update textarea value.
 *   2. Settings.astro's readSettings() reads the MUTATED DOM → dispatches
 *      pilcrow:settings-changed with { source: 'init', settings: <restored> }.
 *   3. Editor.astro: textarea already has restored markdown; its init
 *      dispatch fires with source: 'init' (no explicit init dispatch exists
 *      in Editor — the editor only dispatches on user input).
 *   4. Preview.astro: receives settings-changed (restored state) and runs
 *      typeset with the restored markdown.
 *
 * The 'restore' source is used on the explicit editor-changed dispatch so
 * that consumers can distinguish "replaying share-URL state" from a user
 * typing keystroke or paste. Settings.astro doesn't need a restore dispatch
 * because the DOM mutation + readSettings() path carries the state without
 * an explicit event.
 */
---

<Base title="Pilcrow Playground" chrome="minimal">
  {/* Google Fonts — playground-only payload for the five non-Fraunces
      families in the picker. Fraunces continues to load locally via
      global.css's @font-face declarations (the wider site already serves
      Fraunces from /public/fonts/, so duplicating it here would be
      wasteful). The other five are body-tuned editorial serifs not used
      anywhere else on the site, so a single CSS2 stylesheet request is
      cheaper than self-hosting their TTFs. Variable axes (opsz, wght,
      ital) are requested as ranges so future weight/opsz controls work
      without re-requesting the URL. */}
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400..700;1,6..72,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400&family=EB+Garamond:ital,wght@0,400..700;1,400&family=Crimson+Pro:ital,wght@0,400..700;1,400&family=Literata:ital,opsz,wght@0,7..72,400..700;1,7..72,400&display=swap"
    />
  </Fragment>
  <main class="playground" aria-labelledby="playground-title">
    <header class="playground-header">
      <h1 id="playground-title">Playground</h1>
      <p class="playground-lede">
        Paste prose. Pick a typeface. See Pilcrow's editorial typesetting applied live.
      </p>
    </header>

    {/* Settings panel — sub-task 6 SHIPPED. Top bar on desktop; collapses
        above the editor/preview tabs on mobile. The wrapper <section> keeps
        its id and aria-labelledby (the Settings component renders the
        h2#playground-settings-label inside). data-placeholder remains as a
        DOM hook for sub-task 9 share-URL state restoration. */}
    <section
      id="playground-settings"
      class="playground-settings"
      data-placeholder="settings-panel"
      aria-labelledby="playground-settings-label"
    >
      <Settings />
    </section>

    {/* Mobile-only tab toggle. The two radio inputs are PROMOTED to direct
        children of <main> (siblings of `.playground-panes`) so the
        `:checked ~ .playground-panes …` general-sibling selector resolves
        correctly below 768px. Pure CSS — no runtime JS; works with JS
        disabled. The visible <label>s are wrapped in
        `.playground-mobile-tabs` and toggled-visible by the breakpoint. */}
    <input
      type="radio"
      name="playground-pane"
      id="playground-tab-editor"
      class="playground-tab-input"
      checked
    />
    <input
      type="radio"
      name="playground-pane"
      id="playground-tab-preview"
      class="playground-tab-input"
    />
    <div class="playground-mobile-tabs" role="tablist" aria-label="Editor and preview tabs">
      <label for="playground-tab-editor" class="playground-tab-label" role="tab">
        Editor
      </label>
      <label for="playground-tab-preview" class="playground-tab-label" role="tab">
        Preview
      </label>
    </div>

    <div class="playground-panes">
      {/* Editor pane — sub-task 5 SHIPPED. The wrapper <section> keeps
          its id, classes, data-placeholder, and aria-labelledby (the
          Editor component renders the inner h2#playground-editor-label).
          The data-placeholder attr stays as a hook for sub-task 7's
          preview-wiring lookups. */}
      <section
        id="playground-editor"
        class="playground-editor"
        data-placeholder="editor-pane"
        aria-labelledby="playground-editor-label"
      >
        <Editor />
      </section>

      {/* Preview pane — sub-task 7 SHIPPED. The wrapper <section> keeps
          its id, classes, data-placeholder, and aria-labelledby (the
          Preview component renders the inner h2#playground-preview-label).
          The .post-body host inside the Preview component carries the
          editorial cascade (Fraunces, --prose-measure: 65ch, line-height
          1.7) so the typeset output sits at its canonical 65ch measure
          centred inside this wider pane.

          Note: the `font-family: Fraunces` on the parent .playground-preview
          remains as a paint-before-typeset hint for the SSR fallback. */}
      <section
        id="playground-preview"
        class="playground-preview"
        data-placeholder="preview-pane"
        aria-labelledby="playground-preview-label"
      >
        <Preview />
      </section>
    </div>
  </main>
</Base>

<style>
  /* The playground is a tool surface — wider than the editorial 65ch column.
     Body padding (4rem 1rem 2rem from global.css) still applies to .site-nav
     centering, but the playground main expands out to the viewport. */
  .playground {
    max-width: 90rem;
    margin: 0 auto;
  }

  .playground-header {
    margin-bottom: 2rem;
  }

  .playground-header h1 {
    font-family: "Fraunces", ui-serif, Georgia, "Times New Roman", serif;
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin: 0 0 0.25rem;
  }

  .playground-lede {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.95rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }

  /* ─── Settings (top bar) ─────────────────────────────────────────────── */
  .playground-settings {
    border: 1px solid var(--rule);
    padding: 1rem 1.25rem;
    margin-bottom: 1.25rem;
    background: var(--paper);
  }

  /* ─── Mobile tab toggle ──────────────────────────────────────────────── */
  /* Hidden by default on desktop; revealed below 768px via the breakpoint
     block at the bottom. The two <input type="radio"> elements drive sibling
     :checked rules to swap which pane is visible. */
  .playground-mobile-tabs {
    display: none;
  }

  .playground-tab-input {
    /* Visually hidden but accessible to keyboard / SR — same pattern as
       .visually-hidden in global.css. */
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .playground-tab-label {
    flex: 1;
    text-align: center;
    padding: 0.6rem 1rem;
    border: 1px solid var(--rule);
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.85rem;
    color: var(--muted);
    cursor: pointer;
    background: var(--paper);
    user-select: none;
  }

  /* Selected tab takes ink colour; deselected stays muted. The radios sit
     above the tab container as siblings; reach inside via `~` + attribute
     selector since the labels are no longer immediate adjacent siblings. */
  #playground-tab-editor:checked ~ .playground-mobile-tabs label[for="playground-tab-editor"],
  #playground-tab-preview:checked ~ .playground-mobile-tabs label[for="playground-tab-preview"] {
    color: var(--ink);
    border-color: var(--ink);
  }

  /* Keyboard focus ring — meets WCAG focus-visible contract. */
  #playground-tab-editor:focus-visible ~ .playground-mobile-tabs label[for="playground-tab-editor"],
  #playground-tab-preview:focus-visible ~ .playground-mobile-tabs label[for="playground-tab-preview"] {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ─── Two-column panes ───────────────────────────────────────────────── */
  /* Desktop default: editor LEFT, preview RIGHT. Equal columns. The fixed
     gap matches the 2rem rhythm used by the prose grid (column 3 of the
     post-body grid in global.css). */
  .playground-panes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* Each pane is a bordered surface with consistent padding. Min height so
     the placeholder content visibly occupies the layout — when the real
     editor/preview wire in, they'll set their own heights. */
  .playground-editor,
  .playground-preview {
    border: 1px solid var(--rule);
    padding: 1.25rem;
    min-height: 24rem;
    background: var(--paper);
  }

  /* The preview pane is editorial: Fraunces, body line-height. The editor
     and settings panes are tool register: Inter (set per-element below). */
  .playground-preview {
    font-family: "Fraunces", ui-serif, Georgia, "Times New Roman", serif;
    line-height: 1.7;
  }

  /* ─── Placeholder labels (visible in shell) ─────────────────────────── */
  /* Each placeholder region announces its sub-task in Inter so it's obvious
     in the rendered shell what's there and what isn't. Removed when the
     real component lands. */
  .placeholder-label {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }

  .placeholder-hint {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0 0 1rem;
  }

  /* (`.placeholder-sample` was the editor stand-in <pre> in the sub-task 4
     shell; sub-task 5 replaced that with the <Editor /> component which
     owns its own textarea styling. Settings + preview still use
     `.placeholder-label` and `.placeholder-hint` until sub-tasks 6 + 7. */

  /* ─── Mobile fallback (<768px) ───────────────────────────────────────── */
  /* Editor / preview switch via radio tabs; settings stay above as a stacked
     block. The tab labels become the visible UI below this breakpoint. */
  @media (max-width: 767px) {
    .playground-mobile-tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .playground-panes {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* By default below 768px, hide both panes — the :checked rules below
       reveal one at a time. */
    .playground-editor,
    .playground-preview {
      display: none;
    }

    /* Editor tab checked → show editor pane (preview hidden). */
    #playground-tab-editor:checked ~ .playground-panes .playground-editor {
      display: block;
    }

    /* Preview tab checked → show preview pane (editor hidden). */
    #playground-tab-preview:checked ~ .playground-panes .playground-preview {
      display: block;
    }
  }

  /* ─── Compact body padding on the playground ─────────────────────────── */
  /* Global body padding (4rem 1rem 2rem) leaves a deep top inset designed
     for centred prose. The playground reads better with a tighter inset
     so the tools sit closer to the chrome wordmark. */
  :global(body:has(.playground)) {
    padding-top: 2.5rem;
  }
</style>

<script>
  /**
   * Sub-task 9 — share-URL state restoration on page load.
   *
   * Runs as a deferred ES module. Executes BEFORE Settings.astro's
   * hydration script fires its setTimeout(0) init dispatch (document order
   * guarantees this: index.astro's <script> appears earlier in the DOM).
   *
   * Strategy:
   *   1. Parse window.location.hash.
   *   2. If valid v1 share hash: decode via share-url.ts helpers.
   *   3. Mutate the Settings form DOM so readSettings() in Settings.astro
   *      returns the restored state (not the SSR defaults) when its
   *      setTimeout(0) init dispatch fires.
   *   4. Set the editor textarea value + clear data-stand-in.
   *   5. Dispatch pilcrow:editor-changed with { source: 'restore' } so
   *      Preview.astro's latestMarkdown is updated before the first typeset.
   *   6. On any decode failure (malformed hash, version mismatch, etc.):
   *      console.warn + silent fallback to default state.
   *
   * No feedback loop: this script mutates DOM and dispatches one event.
   * Settings.astro's init dispatch reads the mutated DOM and dispatches
   * source: 'init' — that's the only settings event. The restore path
   * does NOT dispatch pilcrow:settings-changed; it lets Settings.astro's
   * normal init path carry the restored values.
   *
   * JS-disabled: this script doesn't run; page renders with default state.
   * Not a regression — the playground already requires JS.
   */

  import { decodeShareURL } from '../../lib/playground/share-url.ts';

  interface PlaygroundSettings {
    font: string;
    dropCap: boolean;
    hyphenation: boolean;
    measure: number;
    lineHeight: number;
  }

  interface PlaygroundWindow extends Window {
    __pilcrowSettings?: PlaygroundSettings;
  }

  interface EditorChangedDetail {
    markdown: string;
    source: 'paste' | 'keystroke' | 'init' | 'restore';
  }

  /**
   * Apply restored settings to the Settings form DOM so that
   * Settings.astro's readSettings() returns the correct state.
   */
  const applySettingsToDOM = (settings: PlaygroundSettings): void => {
    const form = document.querySelector<HTMLFormElement>('[data-settings-form]');
    if (!form) return;

    // ── Font swatches ──────────────────────────────────────────────────────
    const swatches = form.querySelectorAll<HTMLButtonElement>('.font-swatch');
    for (const swatch of swatches) {
      const isTarget = swatch.dataset.font === settings.font;
      swatch.setAttribute('aria-checked', isTarget ? 'true' : 'false');
    }

    // ── Drop-cap toggle ────────────────────────────────────────────────────
    const dropCapInput = form.querySelector<HTMLInputElement>('[data-drop-cap]');
    if (dropCapInput) {
      dropCapInput.checked = settings.dropCap;
    }

    // ── Hyphenation toggle ─────────────────────────────────────────────────
    const hyphenationInput = form.querySelector<HTMLInputElement>('[data-hyphenation]');
    if (hyphenationInput) {
      hyphenationInput.checked = settings.hyphenation;
    }

    // ── Measure stepper ────────────────────────────────────────────────────
    const measureInputs = form.querySelectorAll<HTMLInputElement>('[data-measure]');
    for (const input of measureInputs) {
      input.checked = Number(input.value) === settings.measure;
    }

    // ── Line-height stepper ────────────────────────────────────────────────
    const lineHeightInputs = form.querySelectorAll<HTMLInputElement>('[data-line-height]');
    for (const input of lineHeightInputs) {
      input.checked = Number(input.value) === settings.lineHeight;
    }

    // ── Mirror to window so Preview.astro's late-attach recovery works ─────
    (window as PlaygroundWindow).__pilcrowSettings = settings;
  };

  /**
   * Apply restored markdown to the editor textarea.
   */
  const applyMarkdownToEditor = (markdown: string): void => {
    const textarea = document.getElementById(
      'playground-editor-textarea',
    ) as HTMLTextAreaElement | null;
    if (!textarea) return;

    textarea.value = markdown;
    // Clear the stand-in marker — the content is restored, not the default.
    delete (textarea.dataset as DOMStringMap & Record<string, string>)['standIn'];

    // Dispatch pilcrow:editor-changed with source: 'restore' so Preview.astro
    // updates latestMarkdown before the first typeset runs. Use setTimeout(0)
    // to match Settings.astro's init-dispatch timing — both land in the same
    // event loop turn, and Preview.astro will have attached its listener by
    // then (its script body runs synchronously before any setTimeout callbacks).
    setTimeout(() => {
      const event = new CustomEvent<EditorChangedDetail>('pilcrow:editor-changed', {
        detail: { markdown, source: 'restore' },
        bubbles: true,
      });
      document.dispatchEvent(event);
    }, 0);
  };

  // ─── Main restore logic ──────────────────────────────────────────────────

  const hash = window.location.hash;
  if (hash && hash.startsWith('#v1.')) {
    const decoded = decodeShareURL(hash);
    if (decoded !== null) {
      // Apply settings to DOM first, then markdown (so the editor textarea
      // has the restored content before any keystroke events could fire).
      applySettingsToDOM(decoded.settings);
      applyMarkdownToEditor(decoded.markdown);
    } else {
      // eslint-disable-next-line no-console
      console.warn(
        '[pilcrow:share-url] Failed to decode share URL hash — falling back to defaults.',
        'Hash:', hash.slice(0, 40) + (hash.length > 40 ? '…' : ''),
      );
    }
  }
  // If no hash or unrecognised prefix: page renders with default state.
  // Silently no-op — no console warning for a normal fresh-load.
</script>
