---
import { siteConfig } from '../config/site.ts';

interface Props {
  title: string;
  /** Controls drop cap on the lede paragraph. Absent or true = on; false = off. */
  dropCap?: boolean;
  /**
   * OG slug for the social share image.
   *   - Post pages: pass the post.id (e.g. "hello") → /og/hello.png
   *   - Index page: omit; falls back to /og/index.png
   * Dimensions are always 1200×630 (D2=A).
   */
  slug?: string;
  /**
   * Chrome variant for the top nav.
   *   - 'full' (default): Pilcrow wordmark + Library link. Editorial register.
   *   - 'minimal': Pilcrow wordmark only — no secondary links.
   * Used by the playground (where the editor pane is visually heavy and the
   * surrounding chrome should recede; per Question C of sub-task 4).
   */
  chrome?: 'full' | 'minimal';
}
const { title, dropCap, slug, chrome = 'full' } = Astro.props;

// Canonical site origin — must match astro.config.mjs `site`.
const SITE = 'https://pilcrow.page';
const ogImage = slug
  ? `${SITE}/og/${slug}.png`
  : `${SITE}/og/index.png`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
    {/* Inter on <time>/captions — Google Fonts. Fraunces is self-hosted via
        public/fonts/ + @font-face in global.css; do NOT request it here. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    {/* Drop-cap signal read by pilcrow-typeset integration at build time. */}
    {dropCap !== undefined && <meta name="pilcrow:drop-cap" content={dropCap ? "true" : "false"} />}
    {/* OG / Twitter card meta tags — D2=A 1200×630, D5=A glyph-alone card. */}
    <meta property="og:title" content={title} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    {/* Per-page <head> injection (e.g. the playground's Google Fonts link).
        Pages opt in via `<Fragment slot="head">…</Fragment>`. */}
    <slot name="head" />
  </head>
  <body>
    <nav class="site-nav" aria-label="Primary">
      <a href="/" class="site-nav-mark">Pilcrow <span aria-hidden="true">¶</span></a>
      {chrome === 'full' && (
        <div class="site-nav-links">
          <a href="/library/" class="site-nav-link">Library</a>
          <a href="/playground/" class="site-nav-link">Playground</a>
        </div>
      )}
    </nav>
    <slot />
    {siteConfig.showPilcrowFooter && (
      <footer class="pilcrow-footer">
        <a href="https://pilcrow.page" rel="noopener">Typeset with Pilcrow ¶</a>
        <span aria-hidden="true"> · </span>
        <a href="https://www.chanikul.com/" rel="noopener">Built by Chanikul</a>
      </footer>
    )}
  </body>
</html>
